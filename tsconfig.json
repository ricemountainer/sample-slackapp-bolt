{
    "compilerOptions": {
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "target": "esnext",
        "module": "commonjs",
        "noImplicitAny": false,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "paths": {
            "@/*": [
                "./node_modules/*",
                "./src/types/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}